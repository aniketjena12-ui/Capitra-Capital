# Database connection string (PostgreSQL, e.g. from Supabase or Neon)
# DATABASE_URL: used by the app at runtime (connection pooling safe)
DATABASE_URL="postgresql://postgres:password@localhost:5432/capitra_capital?schema=public"

# DIRECT_URL: used by `prisma migrate` (bypasses pooler, connects directly)
DIRECT_URL="postgresql://postgres:password@localhost:5432/capitra_capital?schema=public"

# NextAuth configuration
NEXTAUTH_SECRET="generate-a-secure-random-32-character-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Razorpay API credentials (get from dashboard.razorpay.com)
# Used server-side (order creation + signature verification)
RAZORPAY_KEY_ID="rzp_test_yourkeyid"
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# Used client-side (Razorpay checkout modal)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_yourkeyid"

# Email Notifications via SMTP (Nodemailer/Resend)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS="re_your_api_key_here"
SMTP_FROM="Capitra Capital <noreply@yourdomain.com>"

# Optional: Override the admin email (defaults to admin@capitracapital.com)
# ADMIN_EMAIL="your-admin@yourdomain.com"
